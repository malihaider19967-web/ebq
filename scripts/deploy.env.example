# Copy to deploy.env (same directory as ubuntu-vps-install.sh) or set path:
#   export DEPLOY_ENV_FILE=/etc/ebq/deploy.env
#
# Git (use SSH URL if you configured a deploy key on the server)
GIT_REPO="https://github.com/yourorg/ebq.git"
GIT_BRANCH="main"
APP_DIR="/var/www/ebq"

# Web
PRIMARY_DOMAIN="app.example.com"
# Extra hostnames (comma-separated, no spaces) — each gets Apache ServerAlias + DNS if Cloudflare enabled
EXTRA_DOMAINS="www.app.example.com"

# Cloudflare DNS (optional — omit to skip API DNS; create records manually at your registrar)
# Token needs Zone.DNS Edit (and Zone.Zone Read to resolve zone by name)
# CLOUDFLARE_API_TOKEN=""
# CLOUDFLARE_ZONE_NAME="example.com"

# Laravel / DB (used when seeding .env if missing keys)
APP_URL="https://app.example.com"
DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="ebq"
DB_USERNAME="ebq"
DB_PASSWORD="change-me-strong-password"

# Email for Let's Encrypt (required when ENABLE_SSL=1)
ADMIN_EMAIL="you@example.com"
ENABLE_SSL="1"
