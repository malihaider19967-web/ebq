# Copy to deploy.env (same directory as ubuntu-vps-install.sh) or set path:
#   export DEPLOY_ENV_FILE=/etc/ebq/deploy.env
#
# ─── Git ──────────────────────────────────────────────────────────────────────
# If you run the installer with sudo, Git runs as root unless you set
# GIT_SSH_IDENTITY_FILE to a readable private key on disk.
GIT_REPO="git@github.com:malihaider19967-web/ebq.git"
GIT_BRANCH="main"
APP_DIR="/var/www/ebq"
# GIT_SSH_IDENTITY_FILE="/home/YOUR_LINUX_USER/.ssh/id_ed25519"

# ─── Web / domains ────────────────────────────────────────────────────────────
PRIMARY_DOMAIN="ebq.io"
# Extra hostnames (comma-separated, no spaces) — each gets Apache ServerAlias
# + DNS A-record (if Cloudflare enabled) + SAN on the Let's Encrypt cert.
EXTRA_DOMAINS="www.ebq.io"
APP_URL="https://ebq.io"
EBQ_PUBLIC_URL="https://ebq.io"

# ─── Cloudflare DNS (optional) ────────────────────────────────────────────────
# Omit both to skip API DNS and create records manually at your registrar.
# Token needs Zone.DNS:Edit + Zone.Zone:Read on the target zone.
# CLOUDFLARE_API_TOKEN=""
# CLOUDFLARE_ZONE_NAME="ebq.io"

# ─── TLS ──────────────────────────────────────────────────────────────────────
ENABLE_SSL="1"
ADMIN_EMAIL="malihaider19967@gmail.com"   # required when ENABLE_SSL=1

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="ebq"
DB_USERNAME="ebq"
DB_PASSWORD="change-me-please"  # use a strong random password in production
# If no DB server is present, MariaDB is installed by default (MySQL-compatible).
# To install Oracle MySQL instead:
# DB_SERVER_PACKAGE="mysql-server"

# ─── Laravel runtime services ─────────────────────────────────────────────────
# Optional: ebq-intelegence Lighthouse API (separate repo, systemd service on the same box).
# If LIGHTHOUSE_API_KEY is set, the installer seeds the corresponding LIGHTHOUSE_* values
# into Laravel's .env so audits get Core Web Vitals for mobile and desktop.
# Grab the key with:  sudo grep ^LIGHTHOUSE_API_KEY /opt/ebq-intelegence/.env
# LIGHTHOUSE_API_URL="http://127.0.0.1:3001"
# LIGHTHOUSE_API_KEY=""
# LIGHTHOUSE_TIMEOUT_S="90"

ENABLE_REDIS="0"         # installs redis-server + php-redis ext, wires REDIS_* in .env
ENABLE_QUEUE_WORKER="1"  # systemd unit: ebq-queue.service (php artisan queue:work)
ENABLE_SCHEDULER="1"     # cron: /etc/cron.d/ebq-scheduler (php artisan schedule:run)

# ─── Admin plugin releases (optional) ────────────────────────────────────────
# Publishing a release from the web UI updates ebq-seo-wp/ebq-seo.php and runs
# ebq:package-plugin. PHP-FPM must be able to write that file and public/downloads/.
# Typical fix (match your PHP-FPM user, often www-data):
#   sudo chown -R www-data:www-data /var/www/ebq/ebq-seo-wp /var/www/ebq/public/downloads
# Or apply from SSH as the deploy user (no web write needed for that step):
#   cd /var/www/ebq && php artisan ebq:apply-plugin-version 2.3.0 --package

# ─── System hardening ─────────────────────────────────────────────────────────
ENABLE_UFW="1"                 # allow 22, 80, 443 and enable firewall
ENABLE_FAIL2BAN="0"            # adds SSH + Apache jails
ENABLE_UNATTENDED_UPGRADES="1" # automatic security updates
ENABLE_SWAP="0"                # create a swapfile (useful on <2GB RAM VPS)
SWAP_SIZE_MB="2048"

# ─── Tuning (optional) ────────────────────────────────────────────────────────
# TIMEZONE="Etc/UTC"
# PHP_VERSION="8.3"
# PHP_MEMORY_LIMIT="512M"
# UPLOAD_MAX_FILESIZE="64M"
# POST_MAX_SIZE="64M"
# PHP_MAX_EXECUTION_TIME="120"
# OPCACHE_MEMORY_MB="192"
