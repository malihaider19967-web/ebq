# When the virtual host DocumentRoot is this project folder (not `public/`), all
# requests are rewritten into `public/`, where Laravel's `public/.htaccess`
# sends them to `index.php`. Prefer setting DocumentRoot to `public/` in Apache
# or the site root in Nginx so this file is not required.

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Optional: if the site is in a subdirectory, uncomment and set the path.
    # RewriteBase /subfolder/

    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Block direct access to `.env` if DocumentRoot points at this folder.
<Files ".env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>
