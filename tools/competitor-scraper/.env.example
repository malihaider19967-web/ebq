# DB credentials are sourced from the Laravel .env (../../.env by default).
# This file is for scraper-only knobs.

# Default crawl caps. Per-scan caps from the admin UI override these
# unless they exceed the server-side ceiling.
COMPETITOR_SCRAPER_MAX_TOTAL_PAGES=1000
COMPETITOR_SCRAPER_MAX_PAGES_PER_EXTERNAL_DOMAIN=5
COMPETITOR_SCRAPER_MAX_DEPTH=4
COMPETITOR_SCRAPER_REQUEST_DELAY_SECONDS=1.0
COMPETITOR_SCRAPER_USER_AGENT="EBQ-CompetitorScraper/1.0 (+https://ebq.io/scraper-info)"

# Override only if running outside the repo (CI, container, ops-managed
# /etc/ebq/.env). Leave unset for the normal in-repo path.
# EBQ_LARAVEL_ROOT=/var/www/ebq
