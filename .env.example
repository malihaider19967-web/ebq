APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FREE=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=growthhub
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Sentry — leave SENTRY_LARAVEL_DSN empty in local/dev to disable.
# Get the DSN from https://sentry.io → your project → Settings → Client Keys.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
# Capture rate for non-error events (0.0–1.0). Default 1.0 = capture all.
SENTRY_SAMPLE_RATE=1.0
# Performance traces — leave unset to disable. 0.1 = 10% sampling for prod.
# SENTRY_TRACES_SAMPLE_RATE=0.1
# Profiling (CPU profiling) — opt-in, applied on top of traces sampling.
# SENTRY_PROFILES_SAMPLE_RATE=0.1
# PII scrubbing — leave false unless you've reviewed PII against privacy policy.
SENTRY_SEND_DEFAULT_PII=false
# Optional release/version stamp for source-map / commit attribution in Sentry.
# SENTRY_RELEASE=

MEMCACHED_HOST=127.0.0.1

# Optional: only if you switch queue or cache to redis
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Production (e.g. Hostinger): create the mailbox in hPanel first (same address as MAIL_USERNAME).
# Use values from Emails → your mailbox → Connect Apps & Devices (SMTP host/port).
# Do not nest quotes (wrong: MAIL_USERNAME="user@domain.com"") — use MAIL_USERNAME=user@domain.com
# Port 465: MAIL_SCHEME=smtps | Port 587: MAIL_SCHEME=smtp (or null; STARTTLS is negotiated)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=273526746830-d8733v3ktv7cirbj8ecqjfd5v0kvgnhk.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://ebq.io/auth/google/callback
GOOGLE_CAP_AUDIENCE=
GOOGLE_CAP_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_CAP_ISSUERS=https://accounts.google.com,accounts.google.com

# Optional: Serper.dev Google SERP API for page-audit readability benchmarking (top organic URLs).
# SERPER_SEARCH_URL=https://google.serper.dev/search
SERPER_API_KEY=

# Optional: ebq-intelegence Lighthouse API — enriches page audits with mobile/desktop Core Web Vitals.
# Lives on loopback (127.0.0.1:3001) alongside the web app. Leave unset to disable CWV enrichment.
LIGHTHOUSE_API_URL=http://127.0.0.1:3001
LIGHTHOUSE_API_KEY=
LIGHTHOUSE_TIMEOUT_S=90

# Optional: Keywords Everywhere API — powers keyword volume/CPC/competition
# AND the competitor-backlinks fetch on audits. One key drives both.
# Credits are paid per lookup; fresh responses are cached 30d. Leave unset to disable.
KEYWORDS_EVERYWHERE_API_KEY=
# KEYWORDS_EVERYWHERE_BASE_URL=https://api.keywordseverywhere.com
# KEYWORDS_EVERYWHERE_FRESH_DAYS=30
# KEYWORDS_EVERYWHERE_BACKLINKS_ENDPOINT=/v1/get_domain_backlinks
# KEYWORDS_EVERYWHERE_BACKLINKS_COUNTRY=us
# KEYWORDS_EVERYWHERE_BACKLINKS_CURRENCY=USD
# KEYWORDS_EVERYWHERE_BACKLINKS_DATASOURCE=g
# Capped at 50 backlinks per competitor, cached 30 days.
# COMPETITOR_BACKLINKS_LIMIT=50
# COMPETITOR_BACKLINKS_FRESH_DAYS=30
SERPER_COST_PER_CALL_USD=
KEYWORDS_EVERYWHERE_COST_PER_KEYWORD_USD=